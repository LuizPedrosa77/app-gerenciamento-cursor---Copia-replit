# Gustavo Pedrosa FX - Backend API
# Copie para .env e ajuste os valores

# App
DEBUG=false
API_V1_STR=/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:SENHA@postgres:5432/gpfx

# JWT - gere com: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - origens permitidas (separadas por vírgula se precisar)
# CORS_ORIGINS=http://localhost:5173,https://fx.hubnexusai.com

# Crypto - chave para criptografar credenciais de corretora (32+ caracteres)
BROKER_CREDENTIALS_KEY=change-me-32-bytes-base64-encoded

# MinIO (S3-compatível) - screenshots por trade
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_SCREENSHOTS=gpfx-screenshots
MINIO_SECURE=false
# URL pública do MinIO (para gerar URLs de acesso às imagens)
# MINIO_PUBLIC_URL=https://minio.fx.hubnexusai.com
